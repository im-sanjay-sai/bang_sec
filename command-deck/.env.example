# Use a Pipecat Cloud public API key for session start, not a pcc_pat_ personal access token.
PIPECAT_CLOUD_API_KEY=
PIPECAT_AGENT_NAME=gradient-bang-bot
PIPECAT_CLOUD_API_BASE=https://api.pipecat.daily.co/v1/public
VITE_MAPBOX_TOKEN=
MAPBOX_TOKEN=

# FastAPI bridge from the cloned forge voice-agent branch.
# Run from ../forge-voice-agent with:
# uvicorn backend.ai.voice_server:app --host 0.0.0.0 --port 8000
VITE_GHOSTLINE_VOICE_SERVER_URL=http://127.0.0.1:8000
